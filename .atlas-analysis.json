  "keyFeatures": [
    "NoSQL database backed by GitHub repositories with AES-128 encryption",
    "Cloud file storage with support for both regular files (<50MB) and large blob files via GitHub Releases",
    "In-App Messaging with customizable dialog styles (Simple, Coupon, Promo) for Android",
    "In-App Updates for apps distributed outside the Play Store",
    "Zero-cost serverless backend using GitHub infrastructure",
    "Android SDK with Google Play Services Task<T> async API",
    "Pure Java SDK for non-Android Java applications",
    "Console Android app for managing projects, data, and messages"
  ],
  "publicApiSurface": [
    "Clorabase.getInstance(username, token, project)",
    "Clorabase.getDatabase() -> Collection / ClorastoreCollection",
    "Clorabase.getStorage() -> ClorabaseStorage",
    "Clorabase.getAPIQuota() -> Quota",
    "Collection.collection(name) / Collection.document(name)",
    "Collection.getDocuments() / Collection.getCollections()",
    "Collection.query() -> Query",
    "Document.getData() / Document.fetch()",
    "Document.setData(Map) / Document.update(Map) / Document.put(key, value)",
    "Document.addItem(list, value) / Document.removeItem(key) / Document.delete()",
    "Query.where(Predicate) / Query.whereGreater / Query.whereLess / Query.whereEqual / Query.orderBy",
    "ClorabaseStorage.directory(name)",
    "ClorabaseStorage.addFile(bytes, name) / ClorabaseStorage.uploadFile(stream, name, listener)",
    "ClorabaseStorage.uploadBlob(stream, name, listener)",
    "ClorabaseStorage.getFile(name) / ClorabaseStorage.getBlobStream(name)",
    "ClorabaseStorage.listFiles() / ClorabaseStorage.delete(name) / ClorabaseStorage.deleteBlob(name)",
    "Clorabase.initInAppMessaging(context) [Android]",
    "Clorabase.initInAppUpdate(context) [Android]",
    "InAppMessaging.fetch() / InAppMessaging.show(context) [Android]",
    "ProgressListener.onProgress(bytesRead, total) / onComplete() / onError(e)"
  ]
