{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Clorabase docs",
  "theme": "mint",
  "colors": {
    "primary": "#ff48e0",
    "light": "#f64dff",
    "dark": "#7a1a7a"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Clorabase/Clorabase"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Clorabase/Clorabase",
      "instagram": "https://instagram.com/x0.rahil",
      "website": "https://clorabase.github.io",
      "linkedin": "https://in.linkedin.com/in/devrahil"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "setup"
            ],
            "icon": "angles-right"
          },
          {
            "group": "Core Features",
            "pages": [
              "database/overview",
              "database/collections-documents",
              "database/querying",
              "storage/overview",
              "storage/files-blobs"
            ],
            "icon": "microchip"
          },
          {
            "group": "Android Features",
            "pages": [
              "android/in-app-messaging",
              "android/in-app-updates"
            ],
            "icon": "mobile"
          },
          {
            "group": "Console App",
            "pages": [
              "console/overview",
              "console/managing-data"
            ],
            "icon": "mobile-retro"
          },
          {
            "group": "Reference",
            "pages": [
              "reference/limits-constraints",
              "reference/error-handling",
              "reference/security",
              "reference/faq"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Java SDK",
            "pages": [
              "api/java/clorabase",
              "api/java/collection",
              "api/java/document",
              "api/java/query",
              "api/java/storage"
            ]
          },
          {
            "group": "Android SDK",
            "pages": [
              "api/android/clorabase",
              "api/android/clorastore",
              "api/android/storage",
              "api/android/messaging",
              "api/android/updates"
            ]
          }
        ]
      }
    ]
  },
  "description": "Clorabase is a free % open source backend (BaaS) alternative for Android/Java apps. Turn your GitHub repo into a NoSQL database and cloud storage for your app. Use database, storage, in-app messages, in-app updates and lot more",
  "favicon": "/images/clorabase.png",
  "seo": {
    "indexing": "all"
  },
  "logo": "/images/clorabase.png",
  "appearance": {
    "default": "system"
  },
  "banner": {
    "content": "Watch the repo for updates",
    "dismissible": true
  },
  "thumbnails": {
    "appearance": "light",
    "background": "/images/clorabase-banner.png"
  },
  "icons": {
    "library": "fontawesome"
  }
}
